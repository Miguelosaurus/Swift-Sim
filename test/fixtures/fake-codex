#!/usr/bin/env node
import { existsSync, writeFileSync } from "node:fs";

const state = process.env.FAKE_CODEX_STATE;
const args = process.argv.slice(2).join(" ");

if (!state) process.exit(2);

if (args === "--version") {
  console.log("codex-cli 1.0.0");
} else if (args === "plugin marketplace list") {
  if (existsSync(`${state}.marketplace`)) {
    console.log(`swift-sim ${process.env.SWIFT_SIM_MARKETPLACE_ROOT}`);
  }
} else if (args.startsWith("plugin marketplace add ") || args === "plugin marketplace upgrade swift-sim") {
  writeFileSync(`${state}.marketplace`, "ready\n");
} else if (args.startsWith("plugin marketplace remove ")) {
  writeFileSync(`${state}.marketplace`, "removed\n");
} else if (args === "plugin list") {
  if (existsSync(`${state}.plugin`)) {
    console.log("swift-sim-companion@swift-sim  installed, enabled  0.2.2+codex.test");
  }
} else if (args.startsWith("plugin add ")) {
  writeFileSync(`${state}.plugin`, "ready\n");
} else if (args.startsWith("plugin remove ")) {
  writeFileSync(`${state}.plugin`, "removed\n");
} else {
  console.error(`Unexpected fake Codex command: ${args}`);
  process.exit(2);
}
